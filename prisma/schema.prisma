  section   String         @db.VarChar(50)
  studyDay  String?        @map("study_day") @db.VarChar(20)
  startTime DateTime?      @map("start_time") @db.Time(4)
  endTime   DateTime?      @map("end_time") @db.Time(4)
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime?      @map("deleted_at") @db.Timestamptz(6)
  createdBy String?        @map("created_by") @db.Uuid
  updatedBy String?        @map("updated_by") @db.Uuid
  deletedBy String?        @map("deleted_by") @db.Uuid
  course    AcademicCourse @relation(fields: [courseId], references: [id])
  room      AcademicRoom   @relation(fields: [roomId], references: [id])
  user      User           @relation("TeachingLoadUser", fields: [userId], references: [id])

  @@map("academic_teaching_loads")
}

// ==============================================================================
// 22. Facility & Booking
// ==============================================================================

model MeetingRoom {
  id        String        @id @default(uuid()) @db.Uuid
  name      String        @db.VarChar(150)
  capacity  Int
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime?     @map("deleted_at") @db.Timestamptz(6)
  createdBy String?       @map("created_by") @db.Uuid
  updatedBy String?       @map("updated_by") @db.Uuid
  deletedBy String?       @map("deleted_by") @db.Uuid
  bookings  RoomBooking[]

  @@map("meeting_rooms")
}

model RoomBooking {
  id            String      @id @default(uuid()) @db.Uuid
  roomId        String      @map("room_id") @db.Uuid
  userId        String      @map("user_id") @db.Uuid
  title         String      @db.VarChar(255)
  startTime     DateTime    @map("start_time") @db.Timestamptz(6)
  endTime       DateTime    @map("end_time") @db.Timestamptz(6)
  attendeeCount Int?        @map("attendee_count")
  msTeamsLink   String?     @map("ms_teams_link") @db.VarChar(2048)
  status        String      @default("confirmed") @db.VarChar(50)
  remark        String?     @db.Text
  statusLog     Json?       @map("status_log") @default("[]")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?   @map("deleted_at") @db.Timestamptz(6)
  createdBy     String?     @map("created_by") @db.Uuid
  updatedBy     String?     @map("updated_by") @db.Uuid
  deletedBy     String?     @map("deleted_by") @db.Uuid
  room          MeetingRoom @relation(fields: [roomId], references: [id])
  user          User        @relation("RoomBookingUser", fields: [userId], references: [id])

  @@map("room_bookings")
}

// ==============================================================================
// 23. Dashboard Stats (manual data)
// ==============================================================================

model DashboardStat {
  id         String   @id @default(uuid()) @db.Uuid
  department String   @db.VarChar(50)
  statType   String   @map("stat_type") @db.VarChar(50)
  month      String   @db.VarChar(7)
  values     Json     @default("{}")
  updatedBy  String?  @map("updated_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([department, statType, month])
  @@map("dashboard_stats")
}

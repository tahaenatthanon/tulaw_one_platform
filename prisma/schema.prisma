generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==============================================================================
// ENUMS
// ==============================================================================

enum UserStatus {
  ACTIVE
  INACTIVE
  MFA_PENDING
  @@map("user_status")
}

// ==============================================================================
// 1. ภูมิศาสตร์ (Geography)
// ==============================================================================

model Region {
  id        Int        @id @default(autoincrement())
  nameTh    String     @map("name_th") @db.VarChar(150)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  provinces Province[]

  @@map("regions")
}

model Province {
  id          Int          @id @default(autoincrement())
  regionId    Int          @map("region_id")
  nameTh      String       @map("name_th") @db.VarChar(150)
  nameEn      String?      @map("name_en") @db.VarChar(150)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  region      Region       @relation(fields: [regionId], references: [id])
  districts   District[]

  @@map("provinces")
}

model District {
  id           Int           @id @default(autoincrement())
  provinceId   Int           @map("province_id")
  nameTh       String        @map("name_th") @db.VarChar(150)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  province     Province      @relation(fields: [provinceId], references: [id])
  subdistricts Subdistrict[]

  @@map("districts")
}

model Subdistrict {
  id            Int            @id @default(autoincrement())
  districtId    Int            @map("district_id")
  nameTh        String         @map("name_th") @db.VarChar(150)
  zipCode       String?        @map("zip_code") @db.VarChar(10)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  district      District       @relation(fields: [districtId], references: [id])
  userAddresses UserAddress[]

  @@map("subdistricts")
}

// ==============================================================================
// 2. หน่วยงาน (Departments)
// ==============================================================================

model Department {
  id            Int            @id @default(autoincrement())
  name          String         @db.VarChar(150)
  contactEmail  String?        @map("contact_email") @db.VarChar(255)
  telephone     String?        @db.VarChar(50)
  location      String?        @db.VarChar(255)
  status        String         @default("active") @db.VarChar(50)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  users         User[]
  documents     Document[]
  eofficeDocuments EofficeDocument[]
  announcements Announcement[]
  announcementSubscriptions AnnouncementSubscription[]

  @@map("departments")
}

// ==============================================================================
// 3. คำนำหน้า (Prefixes)
// ==============================================================================

model Prefix {
  id        Int      @id @default(autoincrement())
  nameTh    String   @map("name_th") @db.VarChar(50)
  nameEn    String?  @map("name_en") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("prefixes")
}

// ==============================================================================
// 4. บทบาท (Roles) & สิทธิ์ (Permissions)
// ==============================================================================

model Role {
  id              Int              @id @default(autoincrement())
  roleCode        String           @unique @map("role_code") @db.VarChar(50)
  nameTh          String           @map("name_th") @db.VarChar(100)
  level           Int              @default(10)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id              Int              @id @default(autoincrement())
  code            String           @unique @db.VarChar(100)
  nameTh          String           @map("name_th") @db.VarChar(255)
  groupName       String           @map("group_name") @db.VarChar(100)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int        @map("role_id")
  permissionId Int        @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ==============================================================================
// 5. ผู้ใช้ (Users)
// ==============================================================================

model User {
  id            String            @id @default(uuid()) @db.Uuid
  email         String            @unique @db.VarChar(255)
  firstNameTh   String            @map("first_name_th") @db.VarChar(100)
  lastNameTh    String            @map("last_name_th") @db.VarChar(100)
  departmentId  Int               @map("department_id")
  passwordHash  String?           @map("password_hash") @db.VarChar(255)
  status        UserStatus        @default(ACTIVE)
  authSource    String            @default("ldap") @map("auth_source") @db.VarChar(20)
  isLocked      Boolean           @default(false) @map("is_locked")
  lastAdSyncAt  DateTime?         @map("last_ad_sync_at") @db.Timestamptz(6)
  ipAddress     String?           @map("ip_address") @db.VarChar(50)
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?         @map("deleted_at") @db.Timestamptz(6)
  createdBy     String?           @map("created_by") @db.Uuid
  updatedBy     String?           @map("updated_by") @db.Uuid
  deletedBy     String?           @map("deleted_by") @db.Uuid
  department    Department        @relation(fields: [departmentId], references: [id])
  userRoles     UserRole[]
  userMfa       UserMfa[]
  userSessions  UserSession[]
  loginHistories LoginHistory[]
  userAddresses UserAddress[]
  auditLogs     AuditLog[]
  documents     Document[]        @relation("OwnerDocuments")
  favorites     Favorite[]
  calendarAttendees CalendarAttendee[]
  announcementSubscriptions AnnouncementSubscription[]
  dashboardUserSettings DashboardUserSetting[]
  pushNotifications PushNotification[]
  notificationReads NotificationRead[]
  adProfile     UserAdProfile?
  hrProfile     HrEmployeeProfile?          @relation("HrProfile")
  ownedProjects Project[]                   @relation("ProjectOwner")
  assignedTasks ProjectTask[]               @relation("TaskAssignee")
  projectMemberships ProjectMember[]        @relation("ProjectMemberUser")
  timesheetEntries ProjectTimesheet[]       @relation("TimesheetUser")
  sentRoutings   EofficeRouting[]           @relation("RoutingSender")
  receivedRoutings EofficeRouting[]         @relation("RoutingReceiver")
  eofficeSignatures EofficeSignature[]      @relation("SignatureUser")
  leaveRequests  HrLeaveRequest[]           @relation("LeaveRequester")
  overtimeRequests HrOvertimeRequest[]      @relation("OvertimeRequester")
  expenseClaims  HrExpenseClaim[]           @relation("ExpenseClaimer")
  attendances    HrAttendance[]             @relation("AttendanceUser")
  payslips       HrPayslip[]                @relation("PayslipUser")
  purchaseRequests ErpPurchaseRequest[]     @relation("PRRequester")
  goodsReceipts  ErpGoodsReceipt[]          @relation("GoodsReceiver")
  roomBookings   RoomBooking[]              @relation("RoomBookingUser")
  teachingLoads  AcademicTeachingLoad[]     @relation("TeachingLoadUser")
  publishedAnnouncements Announcement[]     @relation("AnnouncementPublisher")

  @@map("users")
}

model UserAdProfile {
  id                String    @id @default(uuid()) @db.Uuid
  adObjectGuid      String?   @unique @map("ad_object_guid") @db.Uuid
  adUpn             String?   @unique @map("ad_upn") @db.VarChar(255)
  azureAdObjectId   String?   @unique @map("azure_ad_object_id") @db.VarChar(255)
  adSamAccountName  String?   @map("ad_sam_account_name") @db.VarChar(150)
  adDn              String?   @map("ad_dn") @db.VarChar(255)
  positionTitle     String?   @map("position_title") @db.VarChar(255)
  telephone         String?   @db.VarChar(20)
  mobilePhone       String?   @map("mobile_phone") @db.VarChar(20)
  adAccountControl  Int?      @map("ad_account_control")
  status            String    @default("active") @db.VarChar(50)
  lastSyncAt        DateTime? @map("last_sync_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user              User      @relation(fields: [id], references: [id])

  @@map("user_ad_profiles")
}

model UserRole {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  roleId    Int       @map("role_id")
  startDate DateTime? @map("start_date") @db.Date
  endDate   DateTime? @map("end_date") @db.Date
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedBy String?   @map("deleted_by") @db.Uuid
  user      User      @relation(fields: [userId], references: [id])
  role      Role      @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@map("user_roles")
}

model UserMfa {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  secret         String    @db.VarChar(255)
  backupCodes    Json      @default("[]") @map("backup_codes")
  isEnabled      Boolean   @default(false) @map("is_enabled")
  verifiedAt     DateTime? @map("verified_at") @db.Timestamptz(6)
  failedAttempts Int       @default(0) @map("failed_attempts")
  lastFailedAt   DateTime? @map("last_failed_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy      String?   @map("created_by") @db.Uuid
  updatedBy      String?   @map("updated_by") @db.Uuid
  deletedBy      String?   @map("deleted_by") @db.Uuid
  user           User      @relation(fields: [userId], references: [id])

  @@map("user_mfa")
}

model UserSession {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  jwtId        String    @map("jwt_id") @db.VarChar(255)
  refreshToken String?   @map("refresh_token") @db.VarChar(255)
  device       String?   @db.VarChar(255)
  browser      String?   @db.VarChar(255)
  ipAddress    String?   @map("ip_address") @db.VarChar(50)
  loginTime    DateTime? @map("login_time") @db.Timestamptz(6)
  logoutTime   DateTime? @map("logout_time") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid
  deletedBy    String?   @map("deleted_by") @db.Uuid
  user         User      @relation(fields: [userId], references: [id])

  @@map("user_sessions")
}

model LoginHistory {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  status    String    @default("success") @db.VarChar(50)
  ipAddress String?   @map("ip_address") @db.VarChar(50)
  userAgent String?   @map("user_agent") @db.Text
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedBy String?   @map("deleted_by") @db.Uuid
  user      User      @relation(fields: [userId], references: [id])

  @@map("login_histories")
}

model UserAddress {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @map("user_id") @db.Uuid
  addressType   String      @default("home") @map("address_type") @db.VarChar(50)
  addressDetail String?     @map("address_detail") @db.Text
  subdistrictId Int         @map("subdistrict_id")
  isPrimary     Boolean     @default(false) @map("is_primary")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?   @map("deleted_at") @db.Timestamptz(6)
  createdBy     String?     @map("created_by") @db.Uuid
  updatedBy     String?     @map("updated_by") @db.Uuid
  deletedBy     String?     @map("deleted_by") @db.Uuid
  user          User        @relation(fields: [userId], references: [id])
  subdistrict   Subdistrict @relation(fields: [subdistrictId], references: [id])

  @@map("user_addresses")
}

// ==============================================================================
// 6. Audit Log (ตรวจสอบ)
// ==============================================================================

model AuditLog {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String?   @map("user_id") @db.Uuid
  module        String    @db.VarChar(100)
  action        String    @db.VarChar(100)
  entityType    String?   @map("entity_type") @db.VarChar(100)
  entityId      String?   @map("entity_id") @db.VarChar(50)
  oldValue      String?   @map("old_value") @db.Text
  newValue      String?   @map("new_value") @db.Text
  ipAddress     String?   @map("ip_address") @db.VarChar(50)
  browser       String?   @db.VarChar(100)
  device        String?   @db.VarChar(100)
  userAgent     String?   @map("user_agent") @db.Text
  requestId     String?   @map("request_id") @db.VarChar(100)
  traceId       String?   @map("trace_id") @db.VarChar(100)
  correlationId String?   @map("correlation_id") @db.VarChar(100)
  isSuccess     Boolean   @default(true) @map("is_success")
  statusCode    Int?      @map("status_code")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy     String?   @map("created_by") @db.Uuid
  updatedBy     String?   @map("updated_by") @db.Uuid
  deletedBy     String?   @map("deleted_by") @db.Uuid
  user          User?     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ==============================================================================
// 7. ระบบไฟล์ & เอกสาร (Storage & Documents)
// ==============================================================================

model StorageFile {
  id              String    @id @default(uuid()) @db.Uuid
  fileName        String    @map("file_name") @db.VarChar(150)
  fileSize        BigInt    @map("file_size")
  mimeType        String    @map("mime_type") @db.VarChar(100)
  storageProvider String    @map("storage_provider") @db.VarChar(100)
  bucket          String?   @db.VarChar(100)
  path            String    @db.VarChar(1024)
  checksum        String?   @db.VarChar(255)
  sha256          String?   @db.VarChar(255)
  etag            String?   @db.VarChar(255)
  isVirusScan     Boolean   @default(false) @map("is_virus_scan")
  scanResult      String?   @map("scan_result") @db.VarChar(100)
  thumbnailPath   String?   @map("thumbnail_path") @db.VarChar(1024)
  width           Int?
  height          Int?
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy       String?   @map("created_by") @db.Uuid
  updatedBy       String?   @map("updated_by") @db.Uuid
  deletedBy       String?   @map("deleted_by") @db.Uuid
  documents       Document[]
  documentVersions DocumentVersion[]
  entityAttachments EntityAttachment[]

  @@map("storage_files")
}

model Document {
  id            String            @id @default(uuid()) @db.Uuid
  title         String            @db.VarChar(255)
  poolType      String            @default("personal") @map("pool_type") @db.VarChar(50)
  storageFileId String            @map("storage_file_id") @db.Uuid
  departmentId  Int?              @map("department_id")
  ownerUserId   String            @map("owner_user_id") @db.Uuid
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?         @map("deleted_at") @db.Timestamptz(6)
  createdBy     String?           @map("created_by") @db.Uuid
  updatedBy     String?           @map("updated_by") @db.Uuid
  deletedBy     String?           @map("deleted_by") @db.Uuid
  storageFile   StorageFile       @relation(fields: [storageFileId], references: [id])
  department    Department?       @relation(fields: [departmentId], references: [id])
  owner         User              @relation("OwnerDocuments", fields: [ownerUserId], references: [id])
  tags          DocumentTag[]
  shares        DocumentShare[]
  versions      DocumentVersion[]

  @@map("documents")
}

model DocumentTag {
  id         String    @id @default(uuid()) @db.Uuid
  documentId String    @map("document_id") @db.Uuid
  tagName    String    @map("tag_name") @db.VarChar(100)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy  String?   @map("created_by") @db.Uuid
  updatedBy  String?   @map("updated_by") @db.Uuid
  deletedBy  String?   @map("deleted_by") @db.Uuid
  document   Document  @relation(fields: [documentId], references: [id])

  @@map("document_tags")
}

model DocumentShare {
  id               String    @id @default(uuid()) @db.Uuid
  documentId       String    @map("document_id") @db.Uuid
  sharedWithUserId String    @map("shared_with_user_id") @db.Uuid
  permission       String    @default("view") @db.VarChar(50)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy        String?   @map("created_by") @db.Uuid
  updatedBy        String?   @map("updated_by") @db.Uuid
  deletedBy        String?   @map("deleted_by") @db.Uuid
  document         Document  @relation(fields: [documentId], references: [id])

  @@map("document_shares")
}

model DocumentVersion {
  id            String      @id @default(uuid()) @db.Uuid
  documentId    String      @map("document_id") @db.Uuid
  storageFileId String      @map("storage_file_id") @db.Uuid
  versionNumber String      @map("version_number") @db.VarChar(255)
  changeLog     String?     @map("change_log") @db.Text
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?   @map("deleted_at") @db.Timestamptz(6)
  createdBy     String?     @map("created_by") @db.Uuid
  updatedBy     String?     @map("updated_by") @db.Uuid
  deletedBy     String?     @map("deleted_by") @db.Uuid
  document      Document    @relation(fields: [documentId], references: [id])
  storageFile   StorageFile @relation(fields: [storageFileId], references: [id])

  @@map("document_versions")
}

model EntityAttachment {
  id            String      @id @default(uuid()) @db.Uuid
  entityType    String      @map("entity_type") @db.VarChar(100)
  entityId      String      @map("entity_id") @db.VarChar(50)
  storageFileId String      @map("storage_file_id") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?   @map("deleted_at") @db.Timestamptz(6)
  createdBy     String?     @map("created_by") @db.Uuid
  updatedBy     String?     @map("updated_by") @db.Uuid
  deletedBy     String?     @map("deleted_by") @db.Uuid
  storageFile   StorageFile @relation(fields: [storageFileId], references: [id])

  @@map("entity_attachments")
}

model DocumentAudit {
  id         String   @id @default(uuid()) @db.Uuid
  documentId String   @map("document_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  action     String   @db.VarChar(50)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("document_audits")
}

// ==============================================================================
// 8. Application Hub
// ==============================================================================

model ApplicationCategory {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar(150)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  applications Application[]

  @@map("application_categories")
}

model Application {
  id         String             @id @default(uuid()) @db.Uuid
  name       String             @db.VarChar(150)
  categoryId Int                @map("category_id")
  url        String?            @db.VarChar(2048)
  icon       String?            @db.VarChar(255)
  status     String             @default("active") @db.VarChar(50)
  createdAt  DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime?          @map("deleted_at") @db.Timestamptz(6)
  createdBy  String?            @map("created_by") @db.Uuid
  updatedBy  String?            @map("updated_by") @db.Uuid
  deletedBy  String?            @map("deleted_by") @db.Uuid
  category   ApplicationCategory @relation(fields: [categoryId], references: [id])
  groupMembers ApplicationGroupMember[]

  @@map("applications")
}

model ApplicationGroup {
  id         String                   @id @default(uuid()) @db.Uuid
  name       String                   @db.VarChar(150)
  createdAt  DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime?                @map("deleted_at") @db.Timestamptz(6)
  createdBy  String?                  @map("created_by") @db.Uuid
